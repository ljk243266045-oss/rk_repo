# Copy to .env and fill in. LiteLLM 通过 provider 前缀路由,见 https://docs.litellm.ai/docs/providers

# ---- LLM (聊天/出题/评分) ----
# 取值示例:
#   dashscope/qwen-plus            (通义千问,推荐用于出题/RAG)
#   anthropic/claude-sonnet-4-5    (Claude,推荐用于论文评分)
#   openai/gpt-4o-mini
#   ernie/ernie-4.0
LLM_MODEL=dashscope/qwen-plus

# 论文/案例长文评分专用模型(可与 LLM_MODEL 不同)
ESSAY_GRADER_MODEL=dashscope/qwen-plus

# ---- Embedding (RAG 索引) ----
EMBEDDING_MODEL=dashscope/text-embedding-v3
EMBEDDING_DIM=1024

# ---- API Keys (按用的 provider 填) ----
DASHSCOPE_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- 运行参数 ----
HOST=127.0.0.1
PORT=8765
DB_PATH=data/ruankao.db
NOTES_DIR=../notes
TEXTBOOK_TXT=../系统规划与管理师教程第2版.txt
CONSOLIDATED_NOTES=../系统规划与管理师_全书结构化笔记.md
